# ── AITrendingNow Channel — dedicated secrets ─────────────────────────────────
# This file is loaded FIRST by ai-trending-agent.ts and setup-trending-oauth.ts.
# It isolates AITrendingNow channel credentials from quizbytesdaily's .env.local.
#
# Setup steps:
#   1. Copy this file: cp .env.trending.example .env.trending
#   2. Fill in YOUTUBE_CLIENT_ID + YOUTUBE_CLIENT_SECRET (same OAuth app as .env.local)
#   3. Run: npx tsx scripts/setup-trending-oauth.ts
#      → Authenticates as AITrendingNow channel
#      → Saves TRENDING_YOUTUBE_REFRESH_TOKEN automatically
# ──────────────────────────────────────────────────────────────────────────────

# ── Shared OAuth app credentials (copy from .env.local) ──────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── AITrendingNow channel (auto-filled by setup-trending-oauth.ts) ────────────
TRENDING_YOUTUBE_REFRESH_TOKEN=
TRENDING_YOUTUBE_CHANNEL_ID=UCV5WqyXMzMsWf8XZ1Xi0HCA
